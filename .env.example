# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Railway provides this automatically; set locally for local dev
PORT=8000

# Railway provides this automatically in production; set locally for local dev
# Must be a public HTTPS URL for Telegram webhook (use ngrok/localtunnel locally)
WEBHOOK_URL=

# Supabase credentials (from Supabase dashboard > Settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM API (OpenAI-compatible endpoint, e.g., OpenRouter, OpenAI, local LLM)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

# Optional: Bot identity / personality
BOT_NAME=Neura
BOT_SYSTEM_PROMPT=You are Neura, a helpful, concise, and friendly AI assistant. Be concise but helpful. Use markdown formatting when appropriate.